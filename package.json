{
  "name": "express-pos",
  "version": "1.0.0",
  "description": "Restfull API pos using expressJS etc.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test sspecified\" && exit 1",
    "start": " cross-env NODE_ENV=local nodemon index.js",
    "startAndWatch": "cross-env NODE_ENV=local nodemon --watch src index.js",
    "network": " cross-env NODE_ENV=local nodemon index.js ",
    "db:new": "dbmate --migrations-dir=db/migrations new",
    "db:up": "dbmate --migrations-dir=db/migrations up",
    "db:migrate:local": "cross-env DATABASE_URL=mysql://root:@localhost:3306/pointofsale dbmate --migrations-dir=db/migrations migrate DATABASE_URL=mysql://root:@localhost:3306/pointofsale",
    "db:rollback": "dbmate --migrations-dir=db/migrations rollback",
    "db:up:local": " cross-env DATABASE_URL=mysql://root:@localhost:3306/pointofsale  dbmate --migrations-dir=db/migrations up ",
    "db:up:staging": "dbmate --migrations-dir=db/migrations up",
    "env:encrypt:staging": "dotenvx encrypt -f .env.staging",
    "env:encrypt:production": "dotenvx encrypt -f .env.production",
    "env:decrypt:staging": "dotenvx decrypt -f .env.staging",
    "env:decrypt:production": "dotenvx decrypt -f .env.production"
  },
  "author": "Tomi Mandala Putra",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.0",
    "dotenv": "^9.0.0",
    "express": "^4.17.1",
    "jsonwebtoken": "^8.5.1",
    "multer": "^1.4.2",
    "mysql2": "^2.2.5",
    "nanoid": "^5.1.5",
    "node-cache": "^5.1.2",
    "node-mailjet": "^3.3.1",
    "nodemon": "^2.0.7"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "cross-env": "^10.1.0",
    "dbmate": "^2.31.0"
  }
}
