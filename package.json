{
  "name": "express-pos",
  "version": "1.0.0",
  "description": "Restfull API pos using expressJS etc.",
  "main": "index.js",
  "scripts": {
    "test": "node test/stripe-payment.test.js",
    "start": "nodemon index.js",
    "startAndWatch": "nodemon --watch src index.js",
    "network": "nodemon index.js",
    "db:new": "dbmate --migrations-dir=db/migrations new",
    "db:up": "dbmate --migrations-dir=db/migrations up",
    "db:migrate:local": "dbmate --env-file .env.local --migrations-dir=db/migrations migrate",
    "db:rollback": "dbmate --migrations-dir=db/migrations rollback",
    "db:up:local": "dbmate --env-file .env.local --migrations-dir=db/migrations up",
    "db:down:local": "dbmate --env-file .env.local --migrations-dir=db/migrations down",
    "db:up:staging": "dbmate --migrations-dir=db/migrations up",
    "env:encrypt:staging": "dotenvx encrypt -f .env.staging",
    "env:encrypt:production": "dotenvx encrypt -f .env.production",
    "env:decrypt:staging": "dotenvx decrypt -f .env.staging",
    "env:decrypt:production": "dotenvx decrypt -f .env.production",
    "docker:compose:staging": "docker compose --env-file .env.staging -f compose.yml up -d",
    "docker:compose:production": "docker compose --env-file .env.production -f compose.yml up -d",
    "github:deploy:staging": "gh workflow run \"Deploy Backend to Staging\" --ref staging -f mode=pm2",
    "github:deploy:docker-staging": "gh workflow run \"Deploy Backend to Staging\" --ref staging -f mode=compose",
    "github:deploy:production": "gh workflow run \"Deploy Backend to Production\" --ref master -f mode=pm2",
    "github:deploy:docker-production": "gh workflow run \"Deploy Backend to Production\" --ref master -f mode=compose"
  },
  "author": "Tomi Mandala Putra",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.0",
    "dotenv": "^9.0.0",
    "express": "^4.17.1",
    "jsonwebtoken": "^8.5.1",
    "multer": "^1.4.2",
    "mysql2": "^2.2.5",
    "nanoid": "^5.1.5",
    "node-cache": "^5.1.2",
    "node-mailjet": "^3.3.1",
    "nodemon": "^2.0.7",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "cross-env": "^10.1.0",
    "dbmate": "^2.31.0"
  }
}
